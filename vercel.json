{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 15,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|assets|static|favicon.ico|index.html|vite.svg|logo.*|@vite|manifest.json|@fs).*)",
      "destination": "/index.html"
    }
  ]
}