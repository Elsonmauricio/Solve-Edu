{
  "version": 2,
  "builds": [
    {
      "src": "Backend/src/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "handle": "filesystem" },
    {
      "source": "/api/(.*)",
      "destination": "Backend/src/app.js"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}