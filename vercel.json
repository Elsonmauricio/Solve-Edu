{
  "version": 2,
  "functions": {
    "Backend/src/app.js": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/Backend/src/app.js"
    },
    {
      "source": "/((?!api|assets|static|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}