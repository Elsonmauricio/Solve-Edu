{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "api/index.js"
    },
    {
      "source": "/((?!api|assets|static|favicon.ico|index.html|vite.svg).*)",
      "destination": "/index.html"
    }
  ],
  "cleanUrls": true
}