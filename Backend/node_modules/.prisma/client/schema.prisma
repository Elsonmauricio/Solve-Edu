generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  avatar     String?
  bio        String?
  phone      String?
  role       UserRole @default(STUDENT)
  userType   UserType @default(USER)
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  level      String?  @default("Iniciante")

  // Relationships
  studentProfile StudentProfile? @relation("UserToStudentProfile")
  companyProfile CompanyProfile? @relation("UserToCompanyProfile")

  notifications Notification[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model StudentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("UserToStudentProfile", fields: [userId], references: [id], onDelete: Cascade)

  school       String?
  course       String?
  year         Int?
  skills       String[]
  portfolioUrl String?
  githubUrl    String?
  linkedinUrl  String?

  solutions Solution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("UserToCompanyProfile", fields: [userId], references: [id], onDelete: Cascade)

  companyName String
  companySize String?
  industry    String?
  website     String?
  description String?
  logo        String?

  problems Problem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Problem {
  id          String         @id @default(cuid())
  title       String
  description String
  companyId   String
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  category   ProblemCategory
  difficulty DifficultyLevel @default(INTERMEDIATE)
  tags       String[]

  requirements String[]
  reward       String?
  rewardType   RewardType?
  deadline     DateTime

  status     ProblemStatus @default(ACTIVE)
  isFeatured Boolean       @default(false)

  // Metadata
  views     Int        @default(0)
  solutions Solution[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([category])
  @@index([status])
}

model Solution {
  id          String         @id @default(cuid())
  title       String
  description String
  problemId   String
  problem     Problem        @relation(fields: [problemId], references: [id], onDelete: Cascade)
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  status        SolutionStatus @default(PENDING_REVIEW)
  technologies  String[]
  githubUrl     String?
  demoUrl       String?
  documentation String?

  // Files
  files String[]

  // Ratings
  rating   Float?
  feedback String?

  // Metadata
  views Int @default(0)
  likes Int @default(0)

  // Timestamps
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([problemId])
  @@index([studentId])
  @@index([status])
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String
  data    Json?

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

// Enums
enum UserRole {
  STUDENT
  COMPANY
  ADMIN
  MENTOR
}

enum UserType {
  USER
  VERIFIED
  PREMIUM
}

enum ProblemCategory {
  TECHNOLOGY
  SUSTAINABILITY
  HEALTH
  EDUCATION
  BUSINESS
  DESIGN
  SCIENCE
  ENGINEERING
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum RewardType {
  MONEY
  INTERNSHIP
  PRIZE
  CERTIFICATE
  JOB_OFFER
}

enum ProblemStatus {
  DRAFT
  ACTIVE
  IN_PROGRESS
  COMPLETED
  EXPIRED
  ARCHIVED
}

enum SolutionStatus {
  DRAFT
  PENDING_REVIEW
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  NEEDS_REVISION
  AWARDED
}

enum NotificationType {
  SOLUTION_SUBMITTED
  SOLUTION_REVIEWED
  PROBLEM_EXPIRING
  NEW_MESSAGE
  SYSTEM_UPDATE
  AWARD_RECEIVED
}
